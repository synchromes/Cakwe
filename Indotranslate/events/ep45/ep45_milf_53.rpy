translate indonesian ep45_milf_53_8f2f7fe4:
    # "You've been so busy lately."
    "Akhir-akhir ini kamu sibuk sekali."

translate indonesian ep45_milf_53_a7db72c6:
    # "Maybe you could stay home today?"
    "Mungkin kamu bisa tinggal di rumah hari ini?"

translate indonesian ep45_milf_53_c70c4cea:
    # mc "Tempting offer."
    mc "Tawaran yang menggoda."

translate indonesian ep45_milf_53_a001d48f:
    # "We could make it an unforgettable day."
    "Kita bisa membuat hari ini tidak terlupakan."

translate indonesian ep45_milf_53_dcca4ea7:
    # "I promise you that."
    "Aku janji."

translate indonesian ep45_milf_53_1a228748:
    # mc "You're putting me in a difficult position."
    mc "Mama membuatku berada di posisi yang sulit."

translate indonesian ep45_milf_53_36de783c:
    # mc "I'll think about it, if you don't mind."
    mc "Aku akan memikirkannya, kalau Mama tidak keberatan."

translate indonesian ep45_milf_53_b7a0caf6:
    # "Every second counts, kid."
    "Setiap detik berharga, nak."

translate indonesian ep45_milf_53_1b946a73:
    # mc "Oh, you sure know how to turn me on..."
    mc "Oh, Mama benar-benar tahu cara membuatku terangsang..."

translate indonesian ep45_milf_53_c55c4dd3:
    # mc "Mary asked me to skip cleaning and spend time with her."
    mc "Mama memintaku melewatkan tugas bersih-bersih dan menghabiskan waktu dengannya."

translate indonesian ep45_milf_53_067b4f21:
    # mc "If I agree, the consequences might be dire."
    mc "Kalau aku setuju, konsekuensinya bisa gawat."

translate indonesian ep45_milf_53_fc94af53:
    # mc "The police officer is looking for a reason to bust my ass."
    mc "Petugas polisi itu sedang mencari alasan untuk menangkapku."

translate indonesian ep45_milf_53_d4a6450d:
    # mc "I'd better not risk it..."
    mc "Sebaiknya aku tidak mengambil risiko..."
