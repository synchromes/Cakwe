translate indonesian christie_root_58_1_c093ab78:
    # mc "Well then..."
    mc "Baiklah..."

translate indonesian christie_root_58_1_f3b3831d:
    # mc "Let's cook some potato and eggs..."
    mc "Ayo masak kentang dan telur..."

translate indonesian christie_root_58_1_dddd3cb6:
    # mc "Now slice up sausage, cucumbers, and carrots..."
    mc "Sekarang potong sosis, mentimun, dan wortel..."

translate indonesian christie_root_58_1_8ea6de34:
    # mc "Add some green peas..."
    mc "Tambahkan kacang polong..."

translate indonesian christie_root_58_1_b11bb974:
    # mc "Now just add some mayonnaise and toss it..."
    mc "Sekarang tinggal tambahkan mayones dan aduk..."

translate indonesian christie_root_58_1_daec8fd8:
    # mc "Pepper, salt, parsley leaves ..."
    mc "Merica, garam, daun parsley..."

translate indonesian christie_root_58_1_c8b61664:
    # mc "Now to make some hamburgers..."
    mc "Sekarang membuat beberapa hamburger..."

translate indonesian christie_root_58_1_7fe70eec:
    # mc "Garlic dip, fish in oil... Ohhhhhh fuck, it's going to be delicious!"
    mc "Saus bawang putih, ikan dalam minyak... Ohhhhhh sial, ini pasti enak!"

translate indonesian christie_root_58_end_92f6bb62:
    # mc "Belicimo!"
    mc "Belicimo!"

translate indonesian christie_root_58_fail_ee09c824:
    # "You didn't keep your eye on the dish and it burned."
    "Kamu tidak memperhatikan masakannya dan akhirnya gosong."

translate indonesian christie_root_58_fail_574d7917:
    # "Try again?"
    "Coba lagi?"

