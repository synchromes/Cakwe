translate indonesian final_act_23_7ca1fd60:
    "Halo, Sayang."

translate indonesian final_act_23_765562ac:
    mc "Halo, Marina!"

translate indonesian final_act_23_da21632d:
    mc "Kau tidak tahu betapa aku ingin melihatmu!"

translate indonesian final_act_23_de0d25cc:
    mc "Aku sangat lapar. Aku bisa memakan seekor gajah."

translate indonesian final_act_23_ba9a922b:
    "Ahhh... Kasihan sekali anakku."

translate indonesian final_act_23_7254302d:
    "Baiklah, aku di sini untuk menjagamu."

translate indonesian final_act_23_23bd7d12:
    mc "Kau berhasil membawakanku sedikit makanan?"

translate indonesian final_act_23_98d3c2fa:
    "Kau meragukanku?"

translate indonesian final_act_23_2df59065:
    mc "Tidak akan pernah!"

translate indonesian final_act_23_8333cde4:
    mc "Sejauh ini hanya kau yang membuatku tetap hidup di sini, Mary."

translate indonesian final_act_23_c8eec599:
    "Hei! Apa yang terjadi di sini?"

translate indonesian final_act_23_9560031a:
    "Eh, Pak Polisi?.."

translate indonesian final_act_23_619daf55:
    mc "Apa maumu? Kami sedang bertemu!"

translate indonesian final_act_23_c032fe8b:
    "Petugas jaga baru saja memberitahuku tentang yang disebut 'pertemuan' kalian."

translate indonesian final_act_23_8ed2f04a:
    "Kamera merekam Marina menyerahkan sebuah benda kepada Anda, [mc], dan menurut aturan kami itu jelas dilarang."

translate indonesian final_act_23_88e885d7:
    "Pertama, aku harus menyita barang terlarang itu."

translate indonesian final_act_23_47704715:
    "Kedua, Marina tidak akan bisa mengunjungimu lagi."

translate indonesian final_act_23_1f43be08:
    mc "Kau tidak berhak melakukan itu!!!"

translate indonesian final_act_23_fc7be02f:
    "Aku hanya mematuhi hukum, dasar bodoh."

translate indonesian final_act_23_12d40888:
    "Aku hanya melakukan apa yang harus kulakukan."

translate indonesian final_act_23_27daa6c4:
    "Dasar bajingan."

translate indonesian final_act_23_12887123:
    "Apa?! Apa katamu?!!"

translate indonesian final_act_23_19c9226c:
    "Bersihkan telingamu, bajingan!"

translate indonesian final_act_23_d6c9c8b1:
    "Selamat bersenang-senang, [mc]."

translate indonesian final_act_23_f188a59f:
    "Kau membuat keadaanmu sendiri jauh lebih buruk."

translate indonesian final_act_23_7171431b:
    mc "..."

translate indonesian final_act_23_785eb110:
    mc "Sial..."

translate indonesian final_act_23_1e8b4066:
    mc "Apa yang harus kulakukan sekarang?.."

translate indonesian strings:
    old "Я умираю с голоду…"
    new "Aku mati kelaparan..."
