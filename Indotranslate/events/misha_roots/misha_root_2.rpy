translate indonesian misha_root_1_75_6e4cc338:
    # mc "A new message from Mishwanda... I should read it, maybe it's something important"
    mc "Pesan baru dari Mishwanda... Aku harus membacanya, mungkin ada sesuatu yang penting."

translate indonesian misha_root_2_ae842789:
    # mc "This girl's playing with me."
    mc "Gadis ini sedang mempermainkanku."

translate indonesian misha_root_2_707834c0:
    # mc "Though, do I really mind?"
    mc "Tapi, apa aku benar-benar keberatan?"

translate indonesian misha_root_2_c0c76f51:
    # mc "Well, guess we'll see how it goes."
    mc "Yah, kita lihat saja nanti bagaimana hasilnya."

