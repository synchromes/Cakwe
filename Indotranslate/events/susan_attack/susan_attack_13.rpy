translate indonesian susan_attack_13_bc0b423f:
    # psi "Hey, what are you doing here?"
    psi "Hei, apa yang kamu lakukan di sini?"

translate indonesian susan_attack_13_c9614380:
    # psi "[mc], I don't remember us agreeing about meeting again."
    psi "[mc], seingatku kita tidak sepakat untuk bertemu lagi."

translate indonesian susan_attack_13_693638b8:
    # mc "Well, I've come for a dessert, he-heh."
    mc "Yah, aku datang untuk makanan penutup, he-heh."

translate indonesian susan_attack_13_17294ff5:
    # psi "I don't mind but I'm not prepared..."
    psi "Aku tidak keberatan, tapi aku belum siap..."

translate indonesian susan_attack_13_bf613e3f:
    # psi "Another «robbery» might be too suspicious for my husband."
    psi "«Perampokan» lagi mungkin akan terlalu mencurigakan bagi suamiku."

translate indonesian susan_attack_13_05e5856b:
    # mc "Oh, don't worry. I've got it all covered."
    mc "Oh, jangan khawatir. Aku sudah mengatur semuanya."

translate indonesian susan_attack_13_3f85a75b:
    # officer "It's you again, you little assholes?!.."
    officer "Kalian lagi, dasar bajingan kecil?!.."

translate indonesian susan_attack_13_bf39cec1:
    # mc "Hands in the air, cop. This time it's no toy gun!"
    mc "Angkat tangan, polisi. Kali ini bukan pistol mainan!"

translate indonesian susan_attack_13_f1703891:
    # mc "Though, it's actually a toy gun."
    mc "Walaupun sebenarnya ini pistol mainan."

translate indonesian susan_attack_13_ef099eff:
    # mc "And the cop knows about it."
    mc "Dan polisi itu tahu soal itu."

translate indonesian susan_attack_13_12112908:
    # officer "Okay, okay. Just don't shoot me."
    officer "Oke, oke. Jangan tembak aku."

translate indonesian susan_attack_13_e2fa665b:
    # mc "Man, get over here and tie him up."
    mc "Bro, kemari dan ikat dia."

translate indonesian susan_attack_13_2405c0c4:
    # igr "Roger that!"
    igr "Dimengerti!"
