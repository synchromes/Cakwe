translate indonesian susan_attack_2_ce5b516e:
    mc "Aku ingin bicara dengan suamimu, Susan."

translate indonesian susan_attack_2_493cc205:
    mc "Aku ingin menceritakan semuanya padanya."

translate indonesian susan_attack_2_0ffac7b9:
    psi "Ah, ayolah!"

translate indonesian susan_attack_2_b5bf467d:
    psi "Kau takut setelah melihat itu dia ingin balas dendam?"

translate indonesian susan_attack_2_1e9ae43a:
    mc "....................."

translate indonesian susan_attack_2_e59f4439:
    psi "Tenanglah, Nak."

translate indonesian susan_attack_2_dab663d2:
    psi "Kalau kau datang ke sini masih utuh, itu berarti suamiku tidak ingin menyakitimu."

translate indonesian susan_attack_2_af62e479:
    mc "Lalu bagaimana denganmu?"

translate indonesian susan_attack_2_2984396e:
    psi "Ayo ke kantorku. Akan kuceritakan."

translate indonesian susan_attack_2_60b26fed:
    mc "Menurutku itu bukan ide bagus."

translate indonesian susan_attack_2_06672608:
    psi "Ha-ha-ha!"

translate indonesian susan_attack_2_1ab2c535:
    psi "Kali ini aku tidak akan menawarimu teh. Ayo."

translate indonesian susan_attack_2_1185a064:
    mc "Baiklah."

translate indonesian susan_attack_2_33be7823:
    psi "Seperti yang kau lihat, aku baik-baik saja. Bahkan suasana hatiku sangat bagus hari ini."

translate indonesian susan_attack_2_a9f6b647:
    mc "Meski dia melihat kita waktu itu?!"

translate indonesian susan_attack_2_30c20589:
    psi "Tentu saja."

translate indonesian susan_attack_2_e40dd519:
    psi "Kami tidak berpisah. Justru kami memutuskan untuk memulai ulang hubungan kami."

translate indonesian susan_attack_2_9cef69c5:
    mc "Memu... APA?!!"

translate indonesian susan_attack_2_8872782e:
    mc "Aku tidak percaya."

translate indonesian susan_attack_2_f1f8ccc1:
    psi "Saat dia melihat kita bercinta, akhirnya dia pasti menyadari betapa berharganya aku dan hubungan kami baginya."

translate indonesian susan_attack_2_aa2b88b3:
    psi "Dia menyalahkan dirinya sendiri atas apa yang terjadi."

translate indonesian susan_attack_2_ddb92c98:
    psi "Dia sadar dialah yang mendorongku tidak setia, bahkan dia menyesalinya."

translate indonesian susan_attack_2_2ab87601:
    mc "Dan kau tetap bertekad tinggal bersamanya?"

translate indonesian susan_attack_2_d2ac62f4:
    psi "Maaf kalau aku belum siap menghancurkan pernikahan yang sudah bertahun-tahun kujalani, [mc]."

translate indonesian susan_attack_2_dc25711e:
    psi "Kami punya terlalu banyak hal bersama."

translate indonesian susan_attack_2_b6d23f09:
    psi "Selain itu, aku sudah terbiasa dengan standar hidup tertentu."

translate indonesian susan_attack_2_5c090e89:
    mc "....................."

translate indonesian susan_attack_2_993ac89c:
    psi "Berhenti menatapku seperti itu, [mc]."

translate indonesian susan_attack_2_321b05cf:
    psi "Sejak kapan kau jadi penjaga moral?"

translate indonesian susan_attack_2_b6c1b6fb:
    psi "Kau lebih tahu dariku bahwa kebiasaan lama tidak berubah begitu saja dalam sekejap."

translate indonesian susan_attack_2_13399447:
    mc "Baik, baik. Aku hanya ingin tahu bahwa tidak ada yang berada dalam bahaya dibunuh polisi haus darah itu, dan semua orang baik-baik saja."

translate indonesian susan_attack_2_21be5dc9:
    psi "Ah, lihat ini. Sang Lancelot mulia sendiri!"

translate indonesian susan_attack_2_0363c821:
    mc "Kurang lebih begitu."

translate indonesian susan_attack_2_43d3bc36:
    mc "Sampai jumpa."

translate indonesian strings:
    old "И это всё?"
    new "Dan cuma itu?"
