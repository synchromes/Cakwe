translate indonesian ep2_17_trashbin_339022d3:
    # mc "Lived young and died young."
    mc "Hidup muda, mati muda."

translate indonesian ep2_17_trashbin_74f0a534:
    # mc "Not now, someone might see me."
    mc "Jangan sekarang, nanti ada yang lihat."

translate indonesian ep2_17_trashbin_8168d8dc:
    # mc "I should come in the evening."
    mc "Aku harus datang malam nanti."

translate indonesian ep2_17_trashbin_stump_7782580b:
    # mc "I'm not doing this without gloves."
    mc "Aku nggak akan ngelakuin ini tanpa sarung tangan."
