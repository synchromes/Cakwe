translate indonesian ep3_milf_25_b145c90b:
    # "[mc], have you decided to come with us?"
    "[mc], kamu memutuskan untuk ikut dengan kami?"

translate indonesian ep3_milf_25_1c843d60:
    # mc "Sadly..."
    mc "Sayangnya..."

translate indonesian ep3_milf_25_43bed496:
    # mc "I just wanted to wish you a good evening."
    mc "Aku hanya ingin mengucapkan semoga malam kalian menyenangkan."

translate indonesian ep3_milf_25_b504b198:
    # "Good luck, mate!"
    "Semoga beruntung, sobat!"

translate indonesian ep3_milf_25_57bef290:
    # "We'll miss you, [mc]."
    "Kami akan merindukanmu, [mc]."

translate indonesian ep3_milf_25_5a5c897a:
    # mc "I'll try not to"
    mc "Aku akan berusaha tidak begitu."

translate indonesian ep3_milf_25_8a8ae9aa:
    # mc "All done. Now I should send a message to Igor and get him here."
    mc "Selesai. Sekarang aku harus mengirim pesan ke Igor dan menyuruhnya datang ke sini."

translate indonesian strings:
    old "Написать СМС Игорю."
    new "Kirim SMS ke Igor."
    old "GG: Сектор очищен. \nВечером жду у себя."
    new "GG: Sektor aman. \nAku menunggumu di tempatku malam ini."
    old "TT: Понял-принял."
    new "TT: Dimengerti."
