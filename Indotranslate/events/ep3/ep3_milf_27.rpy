translate indonesian ep3_milf_27_2_9c15b896:
    # mc "What's this?"
    mc "Apa ini?"

translate indonesian ep3_milf_27_2_44b7e03c:
    # "A disguise costume."
    "Kostum penyamaran."

translate indonesian ep3_milf_27_2_5b68e6fd:
    # "Just in case things go south."
    "Untuk berjaga-jaga kalau keadaan jadi kacau."

translate indonesian ep3_milf_27_2_4462a1e0:
    # mc "I wouldn't be surprised if you took a gun."
    mc "Gue nggak akan kaget kalau lo bawa pistol."

translate indonesian ep3_milf_27_2_6a2d46c7:
    # "I did."
    "Memang."

translate indonesian ep3_milf_27_2_15c00047:
    # mc "You fucking nutjob!"
    mc "Dasar orang gila!"

translate indonesian ep3_milf_27_2_a59264cf:
    # "You're no better than me."
    "Lo juga nggak lebih baik dariku."

translate indonesian ep3_milf_27_2_4dda6b3e:
    # mc "Uh-huh. Anyway, Mary's room is all yours. You've got an hour and a half, just like you asked. You need anything from me?"
    mc "Uh-huh. Pokoknya, kamar Mama sepenuhnya milik lo. Lo punya satu setengah jam, seperti yang lo minta. Ada yang lo butuhkan dariku?"

translate indonesian ep3_milf_27_2_ffdf7ef3:
    # "Just don't get in the way."
    "Jangan mengganggu saja."

translate indonesian ep3_milf_27_2_61c1d740:
    # mc "Alright."
    mc "Baiklah."

translate indonesian ep3_milf_27_2_11a5ed81:
    # mc "Try to do it as fast as you can."
    mc "Usahakan secepat mungkin."

translate indonesian ep3_milf_27_2_1391f6e4:
    # "Hey, smartass. How about you go crack that safe?"
    "Hei, sok pintar. Bagaimana kalau lo pergi membobol brankas itu?"

translate indonesian ep3_milf_27_2_753b1c18:
    # mc "Alright, alright, I'm gone!"
    mc "Baiklah, baiklah, gue pergi!"

translate indonesian strings:
    old "Вернуться в свою комнату, дождавшись, пока Игорь взломает сейф."
    new "Kembali ke kamarmu dan tunggu sampai Igor membobol brankas."
