translate indonesian ep4_milf_38_781c2d22:
    # mc "Mary, I've got a surprise for you."
    mc "Mama, aku punya kejutan untuk Mama."

translate indonesian ep4_milf_38_c28ff499:
    # "That's very sweet of you. But I'm not in the mood to enjoy life right now..."
    "Kamu baik sekali. Tapi sekarang Mama sedang tidak ingin menikmati hidup..."

translate indonesian ep4_milf_38_0f2cc64c:
    # mc "Did something happen?"
    mc "Ada sesuatu yang terjadi?"

translate indonesian ep4_milf_38_ec42eef9:
    # "Unfortunately, yes."
    "Sayangnya, iya."

translate indonesian ep4_milf_38_75ff0338:
    # mc "Is this about you and me?"
    mc "Ini soal aku dan Mama?"

translate indonesian ep4_milf_38_46e5beff:
    # "Yeah."
    "Iya."

translate indonesian ep4_milf_38_ffffd34a:
    # mc "Well, what are you waiting for? Just tell me."
    mc "Kalau begitu, apa yang Mama tunggu? Katakan saja."

translate indonesian ep4_milf_38_16b12984:
    # "Can we discuss this later? I'll stop by your room in the first half of day."
    "Bisakah kita bahas ini nanti? Mama akan mampir ke kamarmu di paruh awal hari."

translate indonesian ep4_milf_38_b8784533:
    # mc "Sure. I'll be waiting."
    mc "Tentu. Aku akan menunggu."

translate indonesian ep4_milf_38_6b18480f:
    # "Thanks"
    "Terima kasih."

translate indonesian strings:
    old "Дождаться Марину днём в своей комнате."
    new "Tunggu Mama di kamarmu pada siang hari."
