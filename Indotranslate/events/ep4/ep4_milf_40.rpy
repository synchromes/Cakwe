translate indonesian ep4_milf_40_182af91c:
    # mc "Mary, it's time to turn you into Cinderella."
    mc "Mama, saatnya mengubah Mama menjadi Cinderella."

translate indonesian ep4_milf_40_2b4cdfc6:
    # "But I thought you specialised more in stepmothers."
    "Tapi kupikir spesialisasimu lebih ke mama tiri."

translate indonesian ep4_milf_40_f381e740:
    # mc "Ha, that's a good one."
    mc "Ha, bagus juga."

translate indonesian ep4_milf_40_758a59fa:
    # mc "Alright, let's get dressed and go to the clothes shop."
    mc "Baiklah, ayo berpakaian dan pergi ke toko pakaian."

translate indonesian ep4_milf_40_069261d6:
    # "Sure, give me a minute."
    "Tentu, beri aku sebentar."

translate indonesian ep4_milf_40_1669f54c:
    # "I'm ready."
    "Aku siap."

translate indonesian ep4_milf_40_c26fc429:
    # mc "Let's go then!"
    mc "Kalau begitu ayo pergi!"

