# Indonesian translation patch for Milf's Plaza.
# Source: tl/eng/events/biblio/biblio_8.rpyc

translate indonesian biblio_8_success_4f34ecf3:
    # mc "«I love lilies of the valley.»"
    mc "«Aku suka lily lembah.»"

translate indonesian biblio_8_success_945d50fa:
    # mc "Well then, you don't have to ask me twice. I know what I need to do!"
    mc "Kalau begitu, nggak perlu diminta dua kali. Aku tahu harus melakukan apa!"

translate indonesian biblio_8_success_79996a75:
    # mc "I need to find some lilies of the valley and give them to Nancy."
    mc "Aku harus mencari lily lembah dan memberikannya ke Nancy."

translate indonesian biblio_8_success_579be1de:
    # mc "Though, it's not the time for lilies. I doubt I'd find them in the park at this time of the year..."
    mc "Tapi sekarang bukan musim lily. Aku ragu bisa menemukannya di taman pada waktu seperti ini..."

translate indonesian strings:
    old "Найти того, кто знает, как добыть ландыши."
    new "Cari seseorang yang tahu cara mendapatkan lily lembah."
