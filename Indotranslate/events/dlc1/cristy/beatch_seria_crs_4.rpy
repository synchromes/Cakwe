translate indonesian beatch_seria_crs_4_bc5fb563:
    adm "Cepat sekali kau kembali. Sudah menemukan hartanya?"

translate indonesian beatch_seria_crs_4_b4f5e573:
    "Belum. Belum!"

translate indonesian beatch_seria_crs_4_8f24c491:
    crs "Kami butuh sekop, Tuan."

translate indonesian beatch_seria_crs_4_7fa7c965:
    adm "Tuan Smith."

translate indonesian beatch_seria_crs_4_2ef25adf:
    crs "Ya. Bisa pinjamkan satu untuk kami?"

translate indonesian beatch_seria_crs_4_d7812587:
    adm "Dengan senang hati."

translate indonesian beatch_seria_crs_4_bdccb5ec:
    crs "Hore!"

translate indonesian beatch_seria_crs_4_c133d5ed:
    adm "30 dolar."

translate indonesian beatch_seria_crs_4_3bfc4311:
    crs "Apa?!"

translate indonesian beatch_seria_crs_4_a9d9b5d2:
    "30 dolar untuk sebuah sekop?!"

translate indonesian beatch_seria_crs_4_6f816fb0:
    adm "Apa saya yang menawarkannya kepadamu? Tidak, kalian yang memohon untuk itu."

translate indonesian beatch_seria_crs_4_8b30296f:
    adm "Jadi, kalian sendiri yang menentukan seberapa butuh kalian padanya."

translate indonesian beatch_seria_crs_4_9892c914:
    crs "Ini perampokan, [gg]."

translate indonesian beatch_seria_crs_4_465e764c:
    "...."

translate indonesian beatch_seria_crs_4_f0b63df9:
    "Kita harus membicarakannya."

translate indonesian beatch_seria_crs_4_b6683970:
    adm "Tentu, jangan terburu-buru."

translate indonesian beatch_seria_crs_4_296c317f:
    "Kita harus mengambilnya."

translate indonesian beatch_seria_crs_4_39a77485:
    crs "Kau sudah gila? Pria brengsek ini gila!"

translate indonesian beatch_seria_crs_4_66e9dfd4:
    "Ya, tapi ini risiko yang terhitung. Kalau dia rela membayar 100 dolar untuk menemukannya, kita bisa mendapatkan uang kita kembali dengan mudah."

translate indonesian beatch_seria_crs_4_8a5bff78:
    crs "Kau dengar ucapanmu sendiri? Kau bicara seperti penjudi sialan."

translate indonesian beatch_seria_crs_4_7e9bf648:
    "Mungkin."

translate indonesian beatch_seria_crs_4_2d1d4884:
    "Kita bisa meminta lebih banyak lagi untuk harta itu, atau menyimpannya untuk diri sendiri."

translate indonesian beatch_seria_crs_4_a6f64d08:
    crs "Kau membuatku takut, [gg]."

translate indonesian beatch_seria_crs_4_72d0ee3f:
    "Jadi, kita lakukan ini?"

translate indonesian beatch_seria_crs_4_fbceed9f:
    crs "Itu uangmu, kau yang putuskan."

translate indonesian beatch_seria_crs_4_9409af7a:
    crs "Aku tidak akan memberi bajingan itu satu sen pun."

translate indonesian beatch_seria_crs_4_c38664cf:
    "Baiklah kalau begitu."

translate indonesian beatch_seria_crs_4_4f934bf2:
    "Oke, kami ambil!"

translate indonesian beatch_seria_crs_4_0c80a28e:
    adm "Uangnya dulu."

translate indonesian beatch_seria_crs_4_try_e9a40b64:
    "Kalau kalian berubah pikiran, kembali saja."

translate indonesian beatch_seria_crs_4_try_0c80a28e:
    adm "Bagaimanapun, kita butuh sekop itu."

translate indonesian beatch_seria_crs_4_decline_23d17353:
    adm "Uangnya dulu."

translate indonesian beatch_seria_crs_4_accept_959a480f:
    adm "Ini, ambillah. Saya yakin ini akan berguna untuk kalian."

translate indonesian beatch_seria_crs_4_accept_79dd3bf0:
    "Semoga begitu, Tuan Smith."

translate indonesian beatch_seria_crs_4_accept_6a0bc182:
    adm "Jangan lupa dikembalikan."

translate indonesian beatch_seria_crs_4_accept_1f4a5e9c:
    crs "Apa-apaan?! 30 dolar untuk sewa sekop?! Ini penipuan terang-terangan!"

translate indonesian beatch_seria_crs_4_accept_5af5d1d3:
    adm "Kalau kalian berubah pikiran."

translate indonesian beatch_seria_crs_4_accept_6d35cce2:
    "Tenang, Christie. Kita akan kembali."

translate indonesian beatch_seria_crs_4_accept_fcbcc9ac:
    crs "Gila! Benar-benar gila!"

translate indonesian beatch_seria_crs_4_accept_dfc5d0d1:
    adm "Sekelompok orang bodoh."

translate indonesian beatch_seria_crs_4_accept_3ec3fbeb:
    adm "Aku menyewakan detektor logam rusak kepada dua moron seharga 50 dolar. Lima orang lainnya membeli sekop."

translate indonesian beatch_seria_crs_4_accept_1801e032:
    adm "Cerita harta karun bodoh ini benar-benar menguntungkan."

translate indonesian strings:
    old "Попросить у управляющего лопату."
    new "Minta sekop kepada pengelola."

    old "1. Заплатить 30 долларов."
    new "1. Bayar 30 dolar."

    old "2. Не платить."
    new "2. Jangan bayar."

    old "{color=#555555}1. Заплатить 30 долларов.{/color}"
    new "{color=#555555}1. Bayar 30 dolar.{/color}"
