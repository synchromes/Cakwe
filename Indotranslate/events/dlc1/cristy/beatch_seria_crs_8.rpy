translate indonesian beatch_seria_crs_8a_34aeea56:
    "Baiklah, teman-teman, kami punya dua kabar."

translate indonesian beatch_seria_crs_8a_3178c164:
    zud "Dan tidak ada uang, kan?"

translate indonesian beatch_seria_crs_8a_932f3e50:
    "Ya."

translate indonesian beatch_seria_crs_8a_49b1295b:
    bub ".............!!!!"

translate indonesian beatch_seria_crs_8a_db67a093:
    zud "Bajingan serakah itu menolak membayar?!"

translate indonesian beatch_seria_crs_8a_2c20b7d5:
    crs "Bisa dibilang begitu."

translate indonesian beatch_seria_crs_8a_c4757f54:
    "Kami bisa menyerahkan barang temuannya kepada kalian, lalu kalian bisa mengurusnya sesuka hati."

translate indonesian beatch_seria_crs_8a_e821a303:
    zud "Langkah cerdas, [gg]."

translate indonesian beatch_seria_crs_8a_aff46688:
    zud "Kami akan kembali ke Tuan Smith sialan itu dan setidaknya mengambil bagian kami darinya!"

translate indonesian beatch_seria_crs_8a_026601af:
    "Semoga berhasil!"

translate indonesian beatch_seria_crs_8b_276d0529:
    "Baiklah, teman-teman. Kami sudah mendapatkan uangnya."

translate indonesian beatch_seria_crs_8b_2aabb2e7:
    zud "Berapa banyak?"

translate indonesian beatch_seria_crs_8b_c17578b1:
    "Yah..."

translate indonesian beatch_seria_crs_8b_8b631596:
    crs "Cukup!"

translate indonesian beatch_seria_crs_8b_49b1295b:
    bub "...........!!!"

translate indonesian beatch_seria_crs_8b_63ff7e41:
    zud "Cukup itu berapa? Berapa?"

translate indonesian beatch_seria_crs_8b_b46b85ad:
    "[store.beatch_seria_crs_7_sold_total] dolar."

translate indonesian beatch_seria_crs_8b_bfcbf7cf:
    zud "Tidak banyak."

translate indonesian beatch_seria_crs_8b_16aac83b:
    zud "Tapi tetap saja, kalian memainkan kartu kita dengan cerdas!"

translate indonesian beatch_seria_crs_8b_b3fcb80a:
    zud "Senang berbisnis dengan kalian."

translate indonesian beatch_seria_crs_8b_e7562afe:
    "Semoga beruntung, teman-teman."

translate indonesian beatch_seria_crs_8b_8c330400:
    zud "Dan jaga diri kalian."

translate indonesian strings:
    old "Вернуться к Зудиле и Бубниле."
    new "Kembali ke Zudila dan Bubnila."
