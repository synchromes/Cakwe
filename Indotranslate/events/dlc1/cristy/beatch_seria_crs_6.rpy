translate indonesian beatch_seria_crs_6_baefc5ec:
    # "Hey, guys. We found the 'treasure'."
    "Hei, teman-teman. Kami menemukan 'harta karun' itu."

translate indonesian beatch_seria_crs_6_97132f6e:
    # zud "Ha-ha-haah-aha! Fuck yeah!"
    zud "Ha-ha-haah-aha! Mantap, sial!"

translate indonesian beatch_seria_crs_6_70591f3c:
    # zud "Told you, Blubbermouth! This shit's worth it!"
    zud "Sudah kubilang, Blubbermouth! Benda sialan ini layak diperjuangkan!"

translate indonesian beatch_seria_crs_6_2826ff16:
    # zud "Never give up, never surrender! Left hook, right hook, and a kick to the balls!"
    zud "Jangan pernah menyerah, jangan pernah mundur! Hook kiri, hook kanan, dan tendangan ke biji!"

translate indonesian beatch_seria_crs_6_03c8d2e4:
    # zud "Come on, spill it! How much cash? You do remember our cut is half, right?!"
    zud "Ayo, katakan! Berapa uangnya? Kau ingat bagian kami setengah, kan?!"

translate indonesian beatch_seria_crs_6_db8b8622:
    # "It's a board game."
    "Ini permainan papan."

translate indonesian beatch_seria_crs_6_d7182b9f:
    # zud "What?!"
    zud "Apa?!"

translate indonesian beatch_seria_crs_6_15118d38:
    # crs "An ancient board game. At least, that's what it looks like."
    crs "Permainan papan kuno. Setidaknya, begitulah kelihatannya."

translate indonesian beatch_seria_crs_6_21eef330:
    # zud "Like Dungeons & Dragons?"
    zud "Seperti Dungeons & Dragons?"

translate indonesian beatch_seria_crs_6_25d44f0d:
    # "Maybe. Let’s see!"
    "Mungkin. Mari lihat!"

translate indonesian beatch_seria_crs_6_91121fd8:
    # crs "We didn't dare open it."
    crs "Kami tidak berani membukanya."

translate indonesian beatch_seria_crs_6_20883ba6:
    # zud "Sounds like crap."
    zud "Kedengarannya sampah."

translate indonesian beatch_seria_crs_6_2e7d31fe:
    # zud "At least tell me we can sell it to the manager. Is this what he was looking for?"
    zud "Setidaknya bilang kita bisa menjualnya ke manajer. Apa ini yang dia cari?"

translate indonesian beatch_seria_crs_6_8ce51b73:
    # "We're about to find out."
    "Kita akan segera tahu."

translate indonesian beatch_seria_crs_6_892467dc:
    # zud "This thing just looks like junk. Where are the diamonds? The sapphires? I don't even see any gold plating…"
    zud "Benda ini kelihatan seperti rongsokan. Mana berliannya? Safirnya? Aku bahkan tidak melihat lapisan emas..."

translate indonesian beatch_seria_crs_6_0bb7901e:
    # "The manager promised 200 bucks, not 200 thousand. Otherwise, he wouldn't have sent us to find this 'shit.'"
    "Manajer menjanjikan 200 dolar, bukan 200 ribu. Kalau tidak, dia tidak akan menyuruh kita mencari 'sampah' ini."

translate indonesian beatch_seria_crs_6_7e840633:
    # zud "Fair point."
    zud "Masuk akal."

translate indonesian beatch_seria_crs_6_6d947f11:
    # "Wait here, we'll be back soon."
    "Tunggu di sini, kami akan segera kembali."

translate indonesian strings:
    old "Поделиться с Зудилой и Бубнилой находкой."
    new "Bagikan kabar tentang temuanmu kepada Blubbermouth dan Itchy."
