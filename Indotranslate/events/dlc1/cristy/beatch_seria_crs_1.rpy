translate indonesian beatch_seria_crs_1_70dcf01b:
    # "Hey, Christie. How's the sandcastle architecture going? That's a cool fortress."
    "Hei, Christie. Bagaimana perkembangan arsitektur istana pasirmu? Benteng itu keren."

translate indonesian beatch_seria_crs_1_76c73c20:
    # crs "Ha-ha-ha!"
    crs "Ha-ha-ha!"

translate indonesian beatch_seria_crs_1_8066ba79:
    # crs "That wasn't me. Some boy built it."
    crs "Itu bukan buatanku. Ada anak laki-laki yang membangunnya."

translate indonesian beatch_seria_crs_1_eb6a126c:
    # crs "He told me there's a buried treasure on the beach, and whoever finds it will get a reward from the manager."
    crs "Dia bilang ada harta karun yang terkubur di pantai, dan siapa pun yang menemukannya akan mendapat hadiah dari manajer."

translate indonesian beatch_seria_crs_1_25bb3ca9:
    # "And you believed him?"
    "Dan Kakak percaya padanya?"

translate indonesian beatch_seria_crs_1_14cea5b9:
    # crs "I don't see why he'd lie."
    crs "Aku tidak melihat alasan dia berbohong."

translate indonesian beatch_seria_crs_1_1436a19d:
    # crs "He knows I can always ask the manager myself."
    crs "Dia tahu aku selalu bisa bertanya langsung pada manajer."

translate indonesian beatch_seria_crs_1_4de3313f:
    # "Then what are we waiting for? Let's go find out."
    "Kalau begitu apa yang kita tunggu? Ayo cari tahu."

translate indonesian beatch_seria_crs_1_84db00ae:
    # crs "Good idea. Let's go."
    crs "Ide bagus. Ayo."

translate indonesian strings:
    old "Провести время с Кристи."
    new "Habiskan waktu bersama Christie."
