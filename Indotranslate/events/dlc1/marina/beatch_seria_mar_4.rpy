translate indonesian beatch_seria_mar_4_aa553ca3:
    # "Марина" "I've found your oranges, Mr. Smith."
    "Марина" "Saya sudah menemukan jeruk Anda, Mr. Smith."

translate indonesian beatch_seria_mar_4_de20ae93:
    # adm "I hope they were big enough? Ha-ha-ha!"
    adm "Semoga ukurannya cukup besar? Ha-ha-ha!"

translate indonesian beatch_seria_mar_4_95546b15:
    # "Марина" "Uh, sure."
    "Марина" "Uh, tentu."

translate indonesian beatch_seria_mar_4_ea446465:
    # "Марина" "You did say you'd make me fresh juice with ice in return."
    "Марина" "Anda bilang akan membuatkan saya jus segar dengan es sebagai gantinya."

translate indonesian beatch_seria_mar_4_18d1a7d7:
    # adm "Yes, yes. Apologies. My sense of humor tends to leak out despite my attempts to be tactful, he-heh."
    adm "Ya, ya. Maaf. Selera humor saya suka bocor keluar meski saya berusaha tetap sopan, he-heh."

translate indonesian beatch_seria_mar_4_167a51f9:
    # adm "Here's your freshly squeezed juice, along with a few cubes of ice."
    adm "Ini jus segar Anda, lengkap dengan beberapa es batu."

translate indonesian beatch_seria_mar_4_d834be64:
    # "Марина" "Thank you."
    "Марина" "Terima kasih."
