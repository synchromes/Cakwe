translate indonesian beatch_seria_mar_6_d6b620a3:
    # "Awesome! I've got the sunscreen."
    "Mantap! Aku sudah mendapatkan tabir suryanya."

translate indonesian beatch_seria_mar_6_2a9d0d8b:
    # "Now I can rush back to Marina."
    "Sekarang aku bisa segera kembali ke Marina."

translate indonesian beatch_seria_mar_6_crs_6731ea17:
    # "Christie, could you lend me some sunscreen?"
    "Christie, bisa pinjamkan aku tabir surya?"

translate indonesian beatch_seria_mar_6_crs_395f8149:
    # crs "I'm sorry, [gg], but I used up all the leftovers on myself."
    crs "Maaf, [gg], tapi sisa terakhirnya sudah kupakai semua untuk diriku sendiri."

translate indonesian beatch_seria_mar_6_crs_af09e345:
    # "Oh, I see."
    "Oh, begitu."

translate indonesian beatch_seria_mar_6_zubbub_691cc749:
    # "Guys, I really need sunscreen. Help me out."
    "Guys, aku benar-benar butuh tabir surya. Bantu aku."

translate indonesian beatch_seria_mar_6_zubbub_25fb0407:
    # zud "Dude, we're on vacation! Go bother someone else."
    zud "Dude, kami sedang liburan! Ganggu orang lain saja."

translate indonesian beatch_seria_mar_6_zubbub_4ba04af9:
    # bub "..................."
    bub "..................."

translate indonesian beatch_seria_mar_6_zubbub_7b42b0c9:
    # "You can ask for anything! But I really need some sunscreen."
    "Kalian boleh minta apa saja! Tapi aku benar-benar butuh tabir surya."

translate indonesian beatch_seria_mar_6_zubbub_22a55f84:
    # zud "Some other time, man. We only make deals by Mishwanda's shop."
    zud "Lain kali saja, man. Kami cuma bikin kesepakatan di dekat toko Mishwanda."

translate indonesian beatch_seria_mar_6_zubbub_87c03727:
    # "Mhm, got it..."
    "Mhm, mengerti..."

translate indonesian beatch_seria_mar_6_adm_354ac3fe:
    # "Mr. Smith, this time I need sunscreen. Can you help me?"
    "Tuan Smith, kali ini aku butuh tabir surya. Bisa bantu aku?"

translate indonesian beatch_seria_mar_6_adm_c6db4b74:
    # adm "Eh… That's the one thing I don't have. Need some contraceptives instead?"
    adm "Eh... Justru itu satu-satunya yang tidak saya punya. Butuh kontrasepsi saja?"

translate indonesian beatch_seria_mar_6_adm_1e1705e9:
    # "No."
    "Tidak."

translate indonesian beatch_seria_mar_6_adm_fe209550:
    # adm "Your loss!"
    adm "Rugi sendiri!"

translate indonesian beatch_seria_mar_6_kat_5405d24b:
    # "Hey, Kat, do you happen to have any sunscreen?"
    "Hei, Kat, kebetulan kau punya tabir surya?"

translate indonesian beatch_seria_mar_6_kat_dc55493a:
    # kat "I think I do. Check my bag."
    kat "Kurasa punya. Cek tasku."

translate indonesian beatch_seria_mar_6_kat_bd79d71d:
    # "Oh, thank you! You have no idea how much it means to me."
    "Oh, terima kasih! Kau tidak tahu betapa berartinya ini bagiku."

translate indonesian beatch_seria_mar_6_kat_c0a63efb:
    # kat "Sure, sure."
    kat "Ya, ya."

