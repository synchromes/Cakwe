translate indonesian beatch_seria_sus_2_db52f4a7:
    adm "Ah, ini dia, [gg]. Apa yang bisa kubantu? Lagi!"

translate indonesian beatch_seria_sus_2_f1c9e24d:
    "Aku butuh ban renang."

translate indonesian beatch_seria_sus_2_3456b9d2:
    adm "Bentuk? Ukuran? Warna?"

translate indonesian beatch_seria_sus_2_ab7848b8:
    "Apa saja boleh."

translate indonesian beatch_seria_sus_2_d68e8e04:
    adm "Anda beruntung. Tinggal satu."

translate indonesian beatch_seria_sus_2_3fe80bd6:
    "Boleh kupinjam sebentar?"

translate indonesian beatch_seria_sus_2_ef18a50b:
    adm "Tentu saja."

translate indonesian beatch_seria_sus_2_0d3682c6:
    adm "Harganya 20 dolar."

translate indonesian beatch_seria_sus_2_5aa3252b:
    "Kenapa aku tidak pernah bisa mendapatkan yang kubutuhkan tanpa tugas bodoh atau harus membayar? Pelayanan macam apa ini?!"

translate indonesian beatch_seria_sus_2_2a669e9e:
    adm "Ini pantai liar, [gg]! Ekonomi pasar bebas, belum tersentuh kesombongan kota."

translate indonesian beatch_seria_sus_2_74bf03c6:
    "Bagus. Baiklah."

translate indonesian beatch_seria_sus_2_adm_1e9d1186:
    adm "Masih butuh ban renang itu, [gg]?"

translate indonesian beatch_seria_sus_2_adm_44a74b94:
    "Aku punya."

translate indonesian beatch_seria_sus_2_adm_f878b752:
    adm "Harga sama. Tapi kalau kau terus membuang-buang waktuku, harganya akan naik."

translate indonesian beatch_seria_sus_2_adm_465e764c:
    "...."

translate indonesian beatch_seria_sus_2_zubbub_04c18940:
    "Itchy, bagaimana kalau kau meminjamkan ban renangmu kepadaku?"

translate indonesian beatch_seria_sus_2_zubbub_699447c6:
    zud "Flamingoku? Tidak mungkin!"

translate indonesian beatch_seria_sus_2_zubbub_97502b8a:
    "Bagaimana kalau kubayar?"

translate indonesian beatch_seria_sus_2_zubbub_35c065d8:
    zud "Sobat, ini bukan cuma flamingo. Ini jimat keberuntunganku untuk ombak besar."

translate indonesian beatch_seria_sus_2_zubbub_1d8215be:
    "Kita di danau. Tidak ada ombak!"

translate indonesian beatch_seria_sus_2_zubbub_82c44a2d:
    zud "Aku suka bersiap untuk segala kemungkinan."

translate indonesian beatch_seria_sus_2_zubbub_126e56dc:
    "Aku tidak butuh lama. Cuma beberapa menit."

translate indonesian beatch_seria_sus_2_zubbub_95700063:
    zud "Itu cukup lama untuk membuatku tenggelam."

translate indonesian beatch_seria_sus_2_zubbub_bed4f129:
    zud "Pergi cari orang bodoh lain."

translate indonesian beatch_seria_sus_2_zubbub_d521cf09:
    zud "Ayo pergi, Blubbermouth. [gg] hari ini terlalu berani dengan permintaannya."

translate indonesian beatch_seria_sus_2_zubbub_68f7d2b8:
    bub "..........!"

