translate indonesian ep1_2_morning_eb931c6d:
    # mc "I have to check a text message from a friend."
    mc "Aku harus memeriksa pesan teks dari teman."

translate indonesian ep1_2_morning_2_996a8b17:
    # mc "{i}I'm fucked. Seriously fucked.{/i}"
    mc "{i}Aku kacau. Benar-benar kacau.{/i}"

translate indonesian ep1_2_morning_2_ee6e85ec:
    # mc "{i}If I don't return money to a local thug, I risk losing my pants or something even worse than that.{/i}"
    mc "{i}Kalau aku tidak mengembalikan uang ke preman lokal, aku berisiko kehilangan celanaku atau sesuatu yang lebih buruk dari itu.{/i}"

translate indonesian ep1_2_morning_2_a1436862:
    # mc "{i}I mean, my best friend is going to share this fate with me but it isn't making it any better.{/i}"
    mc "{i}Maksudku, sahabatku juga akan mengalami nasib yang sama denganku, tapi itu tidak membuatnya jadi lebih baik.{/i}"

translate indonesian ep1_2_morning_2_d5462f1d:
    # mc "{i}They've already given us one warning and I'd rather not hear the second one.{/i}"
    mc "{i}Mereka sudah memberi kami satu peringatan dan aku lebih baik tidak mendengar yang kedua.{/i}"

translate indonesian ep1_2_morning_2_9159a582:
    # mc "{i} I don't want Mary to learn about my problems. {/i}"
    mc "{i} Aku tidak ingin Mary tahu tentang masalahku. {/i}"

translate indonesian ep1_2_morning_2_ebb38810:
    # mc "{i} The best thing I could now is try and fix my relationship with her. {/i}"
    mc "{i} Hal terbaik yang bisa kulakukan sekarang adalah mencoba memperbaiki hubunganku dengannya. {/i}"

